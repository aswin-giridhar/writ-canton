# Writ — environment template
#
# Copy to .env.local and fill in. Nothing here is secret as written; the two
# values that ARE secret (OIDC_CLIENT_SECRET, ANTHROPIC_API_KEY) are left blank
# on purpose.
#
#   cp .env.example .env.local

# ─── Canton ledger ──────────────────────────────────────────────────────────
# Participant's JSON Ledger API v2 endpoint. Point this at a local sandbox
# (http://localhost:7575) or at a Devnet validator.
LEDGER_BASE_URL=https://ledger-api.validator.devnet.sandbox.fivenorth.io

# Ledger user the app acts as. On a shared hackathon validator every team
# authenticates through the same user, so this is usually "6".
LEDGER_USER_ID=6

# Package id of the deployed DAR. Changes whenever the Daml source changes —
# read it from the DAR filename after `daml build`.
MANDATE_PACKAGE_ID=a4f6a9b04d0bbbcaf756e21eea0818013213d35547d38708ab21e541b3fb7671

# Package NAME, used for query filters. Canton resolves TemplateFilter by name
# (#mandate-model:Writ.Mandate:Mandate), not by id — a filter built from the
# package id returns zero rows with HTTP 200 while the contracts plainly exist.
MANDATE_PACKAGE_NAME=mandate-model

# The validator's party namespace, including the leading "::". Parties are
# composed as writ-northwind<namespace>. Leave blank to allocate fresh parties
# instead (fine locally, antisocial on a shared validator).
WRIT_PARTY_NAMESPACE=::1220a14ca128063b8dc9d1ebb0bd22633be9f2168500f4dbc1ecaeb1855b14e5acf8

# ─── Ledger auth (OAuth2 client credentials) ────────────────────────────────
# The app runs the grant itself and re-mints at 80% of token lifetime. Devnet
# access tokens live 8 hours, so a pasted static token works on the day you set
# it and is dead by the time anyone else opens the link.
#
# Leave all of this blank for a local sandbox — it runs without auth.
OIDC_TOKEN_URL=https://auth.sandbox.fivenorth.io/application/o/token/
OIDC_CLIENT_ID=validator-devnet-m2m
OIDC_CLIENT_SECRET=
OIDC_AUDIENCE=validator-devnet-m2m
OIDC_SCOPE=daml_ledger_api

# Optional: a pre-minted bearer token, bypassing the grant above. Useful for a
# one-off test; do not ship with it.
# LEDGER_TOKEN=

# ─── Agent ──────────────────────────────────────────────────────────────────
# Optional. Without it, /api/agent returns 503 and the UI reports the agent as
# offline — the direct-order controls still exercise the identical ledger path,
# so the enforcement demo works with no key at all.
ANTHROPIC_API_KEY=
